DB__NAME=your_db_name
DB__USER=your_db_user
DB__PASSWORD=your_strong_db_password
DB__PORT=5432
DB__HOST=your_db_host

JWT__PRIVATE_KEY_PATH=/absolute/path/to/flow/secrets/dev/jwt-private.pem
JWT__PUBLIC_KEY_PATH=/absolute/path/to/flow/secrets/dev/jwt-public.pem

S3__BUCKET=bucket-name
S3__REGION=region
S3__PRESIGN_EXPIRE_SECONDS=900
S3__KEY_PREFIX=
S3__ENDPOINT_URL=

PGADMIN_DEFAULT_EMAIL=your_pgadmin_email
PGADMIN_DEFAULT_PASSWORD=your_strong_pgadmin_password
PGADMIN_PORT=5050
PGADMIN_SERVER_MODE=False
